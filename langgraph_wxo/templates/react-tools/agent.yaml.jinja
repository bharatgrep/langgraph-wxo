spec_version: v1
kind: agent
name: {{ name }}
description: {{ description }}
framework: langgraph
deployment:
  code_bundle:
    entrypoint: agent:create_agent
checkpointer:
  type: {{ checkpointer }}
{%- if checkpointer == "postgres" %}
  connection_string_key: db_connection_string
{%- endif %}
connections:
  # WxO injects this credential at runtime as 'watsonx_gateway_api_key'.
  - app_id: watsonx_gateway
    type: api_key
